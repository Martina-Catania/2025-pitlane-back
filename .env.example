
# Connect to Supabase via connection pooling
DATABASE_URL="postgresql://postgres.uwzrnfxbkoeltqzoirks:[DB-PASSWORD]@[POOLER-HOST]:6543/postgres?pgbouncer=true"

# Connection used by Prisma migrations. Prefer pooler session mode (:5432)
# when db.[PROJECT-REF].supabase.co is not reachable from your network.
DIRECT_URL="postgresql://postgres.uwzrnfxbkoeltqzoirks:[DB-PASSWORD]@[POOLER-HOST]:5432/postgres"

# Supabase Auth values from project settings > API
SUPABASE_URL="https://[PROJECT-REF].supabase.co"
SUPABASE_ANON_KEY="[SUPABASE-ANON-KEY]"

# Secret used by backend to verify JWT tokens
JWT_SECRET="replace-with-a-strong-random-secret"
